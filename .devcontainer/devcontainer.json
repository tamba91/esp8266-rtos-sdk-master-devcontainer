{
  "name": "esp8266-rtos-sdk-master-devcontainer",
  "build": {
    "dockerfile": "Containerfile",
    "context": "."
  },
  "remoteUser": "esp8266",
  "containerUser": "esp8266",
  "updateRemoteUserUID": true,
  "remoteEnv": {
    "ESPPORT": "/dev/ttyUSB0"
  },
  "runArgs": [
    "--name=esp8266-rtos-sdk-master-devcontainer",
    "--userns=keep-id",
    "--hostname=esp8266-rtos-sdk-master-devcontainer",
    "--device=/dev/ttyUSB0",
    "--annotation=run.oci.keep_original_groups=1"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools-extension-pack",
        "seunlanlege.action-buttons"
      ],
      "settings": {
        "C_Cpp.default.compilerPath": "",
        "C_Cpp.default.compileCommands": [
          "${workspaceFolder}/build/compile_commands.json"
        ],
        "C_Cpp.default.includePath": [
          "/home/esp8266/esp/ESP_8266_RTOS_SDK/components/**",
          "${workspaceFolder}/**"
        ],
        "C_Cpp.default.browse.path": [
          "/home/esp8266/esp/ESP_8266_RTOS_SDK/components",
          "${workspaceFolder}"
        ],
        "C_Cpp.default.browse.limitSymbolsToIncludedHeaders": true,
        "cmake.generator": "Ninja",
        "cmake.configureOnOpen": false,
        "cmake.configureOnEdit": false,
        "cmake.automaticReconfigure": false,
        "cmake.showSystemKits": false,
        "cmake.enableAutomaticKitScan": false,
        "cmake.ignoreCMakeListsMissing": true,
        "cmake.options.advanced": {
          "build": { "statusBarVisibility": "hidden" },
          "launch": { "statusBarVisibility": "hidden" },
          "debug": { "statusBarVisibility": "hidden" }
        },
        "actionButtons.commands": [
          { "name": "$(settings-gear) Menuconfig", "command": "idf.py menuconfig", "singleInstance": true },
          { "name": "$(wrench) Build", "command": "idf.py --ccache build", "singleInstance": true },
          { "name": "$(info) IDF Size", "command": "idf.py size", "singleInstance": true },
          { "name": "$(trash) Full Clean", "command": "idf.py fullclean", "singleInstance": true },
          { "name": "$(zap) Flash", "command": "idf.py --ccache -p $ESPPORT flash", "singleInstance": true },
          { "name": "$(close-all) Erase Flash", "command": "idf.py -p $ESPPORT erase_flash", "singleInstance": true },
          { "name": "$(vm) Monitor", "command": "idf.py -p $ESPPORT monitor", "singleInstance": true }
        ]
      }
    }
  }
}
